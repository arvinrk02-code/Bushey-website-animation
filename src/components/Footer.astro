---
import { nav, site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden bg-deep-950 text-white">
  <!-- Ghost type backdrop -->
  <div class="pointer-events-none absolute -bottom-8 left-0 select-none whitespace-nowrap" aria-hidden="true">
    <span class="display text-outline text-[22vw] leading-none text-white/6">BUSHEY 1926</span>
  </div>

  <div class="relative mx-auto max-w-7xl px-5 pb-12 pt-20 sm:px-8">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_2fr]">
      <div>
        <div class="flex items-center gap-3">
          <img
            src="/images/basc-logo-round.jpeg"
            alt=""
            class="h-12 w-12 rounded-full object-cover ring-2 ring-white/20"
            width="48"
            height="48"
            loading="lazy"
          />
          <div class="leading-none">
            <p class="display text-lg">Bushey ASC</p>
            <p class="mt-1 text-[0.6rem] font-bold uppercase tracking-[0.28em] text-gold-400">1926 – 2026</p>
          </div>
        </div>
        <p class="mt-6 max-w-sm text-sm leading-relaxed text-white/60">
          A friendly, volunteer-run competitive swimming club in Hertfordshire, built on sound
          technique and one hundred years of history.
        </p>
        <div class="mt-6 space-y-1.5 text-sm text-white/60">
          <p>{site.address}</p>
          <p>
            <a href={`mailto:${site.email}`} class="text-aqua-300 transition hover:text-aqua-400">{site.email}</a>
          </p>
        </div>
        <div class="mt-6 flex gap-3">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener"
            class="press flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-sm font-bold transition hover:bg-aqua-400 hover:text-deep-900"
            aria-label="Bushey ASC on Instagram"
          >
            IG
          </a>
          <a
            href={site.social.tiktok}
            target="_blank"
            rel="noopener"
            class="press flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-sm font-bold transition hover:bg-aqua-400 hover:text-deep-900"
            aria-label="Bushey ASC on TikTok"
          >
            TT
          </a>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {
          nav.map((group) => (
            <div>
              <p class="eyebrow mb-4 text-aqua-400">{group.label}</p>
              <ul class="space-y-1">
                {group.links.map((link) => (
                  <li>
                    <a href={link.href} class="swim-link inline-block py-1 text-sm text-white/65 transition hover:text-white">
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </div>

    <div class="gold-rule mt-16"></div>

    <div class="mt-6 flex flex-col items-start justify-between gap-4 text-xs text-white/40 sm:flex-row sm:items-center">
      <div class="flex flex-wrap items-center gap-4">
        <span class="rounded-lg bg-white px-3 py-1.5">
          <img src="/images/se-affiliated.png" alt="Swim England Affiliated Club" class="h-6 w-auto" width="122" height="24" loading="lazy" />
        </span>
        <p>© {year} Bushey Amateur Swimming Club.</p>
      </div>
      <div class="flex gap-6">
        <a href="/welfare" class="swim-link inline-block py-1.5 transition hover:text-white">Welfare</a>
        <a href="/club/policies" class="swim-link inline-block py-1.5 transition hover:text-white">Privacy & policies</a>
        <a href={site.swimManagerUrl} target="_blank" rel="noopener" class="swim-link inline-block py-1.5 transition hover:text-white">SwimManager</a>
      </div>
    </div>
  </div>
</footer>
