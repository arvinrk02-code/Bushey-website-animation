---
import WaterCanvas from "./WaterCanvas.astro";
import WaveDivider from "./WaveDivider.astro";

interface Props {
  eyebrow: string;
  title: string;
  strap?: string;
  compact?: boolean;
}

const { eyebrow, title, strap, compact = false } = Astro.props;
---

<section class="relative overflow-hidden bg-white">
  <div
    class="absolute inset-0"
    style="background:
      radial-gradient(110% 90% at 85% -10%, color-mix(in srgb, var(--color-aqua-400) 14%, transparent) 0%, transparent 55%),
      radial-gradient(90% 80% at 0% 110%, color-mix(in srgb, var(--color-foam-200) 70%, transparent) 0%, transparent 60%),
      linear-gradient(180deg, var(--color-foam-50) 0%, #ffffff 100%);"
    aria-hidden="true"
  >
  </div>
  <WaterCanvas variant="light" />

  <div
    class:list={[
      "relative mx-auto max-w-7xl px-5 sm:px-8",
      compact ? "pb-20 pt-32 sm:pb-24 sm:pt-40" : "pb-24 pt-36 sm:pb-32 sm:pt-48",
    ]}
  >
    <p class="eyebrow reveal flex items-center gap-3 text-aqua-600">
      <span class="inline-block h-px w-8 bg-aqua-500" aria-hidden="true"></span>
      {eyebrow}
    </p>
    <h1
      class="display reveal mt-4 max-w-4xl text-[clamp(2.75rem,7.5vw,5.5rem)] text-deep-800"
      style="--reveal-delay: 0.08s"
    >
      {title}
    </h1>
    {
      strap && (
        <p class="reveal mt-6 max-w-2xl text-lg leading-relaxed text-ink-600 sm:text-xl" style="--reveal-delay: 0.16s">
          {strap}
        </p>
      )
    }
    <slot />
  </div>

  <WaveDivider fill="#ffffff" />
</section>
