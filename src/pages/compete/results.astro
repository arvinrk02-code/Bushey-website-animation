---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const results = (await getCollection("results"))
  .map((r) => r.data)
  .sort((a, b) => b.date.valueOf() - a.date.valueOf());

const fmt = (d: Date) => d.toLocaleDateString("en-GB", { day: "numeric", month: "long", year: "numeric" });
---

<Base
  title="Results"
  description="How Bushey ASC got on, gala reports, meet summaries and highlights from recent competitions."
>
  <PageHero
    eyebrow="Compete"
    title="Results"
    strap="How we got on. Full swim-by-swim results are available to members in SwimManager; here's the story of each meet."
    compact
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="space-y-8">
        {
          results.map((r, i) => (
            <article class="card-lift reveal overflow-hidden rounded-3xl border border-foam-200 bg-white" style={`--reveal-delay: ${Math.min(i * 0.07, 0.2)}s`}>
              <div class="grid lg:grid-cols-[1fr_260px]">
                <div class="p-8">
                  <p class="text-xs font-bold uppercase tracking-[0.18em] text-gold-500">{fmt(r.date)} · {r.venue}</p>
                  <h2 class="display mt-2 text-2xl text-deep-800">{r.name}</h2>
                  <p class="mt-3 leading-relaxed text-ink-600">{r.summary}</p>
                </div>
                {r.highlights.length > 0 && (
                  <div class="bg-deep-900 p-8">
                    <h3 class="eyebrow text-aqua-400">Highlights</h3>
                    <ul class="mt-4 space-y-3">
                      {r.highlights.map((h) => (
                        <li class="flex gap-3 text-sm leading-snug text-white/80">
                          <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-gold-400" aria-hidden="true" />
                          {h}
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>
            </article>
          ))
        }
      </div>

      <p class="reveal mt-10 text-center text-sm text-ink-600">
        Members can view every split of every swim in{" "}
        <a href="https://www.swimmanager.co.uk/" target="_blank" rel="noopener" class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4">SwimManager ↗</a>
      </p>
    </div>
  </section>

  <CtaBand />
</Base>
