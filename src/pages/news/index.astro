---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const posts = (await getCollection("news")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const categoryColours: Record<string, string> = {
  "Club news": "bg-aqua-400/15 text-aqua-600",
  "Gala report": "bg-deep-600/12 text-deep-600",
  Centenary: "bg-gold-400/20 text-gold-500",
  Announcement: "bg-foam-200 text-ink-600",
};
---

<Base title="News" description="Bushey ASC club news, gala reports, announcements and centenary updates.">
  <PageHero
    eyebrow="Latest"
    title="Club news"
    strap="Gala reports, announcements and centenary updates from around the club."
    compact
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="grid gap-6">
        {
          posts.map((post, i) => (
            <a
              href={`/news/${post.id}`}
              class="card-lift reveal group grid overflow-hidden rounded-3xl border border-foam-200 bg-white sm:grid-cols-[240px_1fr]"
              style={`--reveal-delay: ${Math.min(i * 0.06, 0.25)}s`}
            >
              {
                post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.imageAlt ?? ""}
                    class="h-44 w-full object-cover sm:h-full"
                    width="480"
                    height="300"
                    loading="lazy"
                  />
                ) : (
                  <div class="flex h-44 items-center justify-center bg-deep-900 sm:h-full" aria-hidden="true">
                    <img src="/images/basc-logo-round.jpeg" alt="" class="h-20 w-20 rounded-full object-cover opacity-90" width="80" height="80" loading="lazy" />
                  </div>
                )
              }
              <div class="p-6 sm:p-8">
                <div class="flex flex-wrap items-center gap-3">
                  <span class:list={["inline-block rounded-full px-3 py-1 text-xs font-bold uppercase tracking-wider", categoryColours[post.data.category]]}>
                    {post.data.category}
                  </span>
                  <span class="text-xs font-bold uppercase tracking-wider text-ink-400">
                    {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                  </span>
                </div>
                <h2 class="mt-3 text-2xl font-bold text-deep-800 transition group-hover:text-aqua-600">{post.data.title}</h2>
                <p class="mt-2 leading-relaxed text-ink-600">{post.data.excerpt}</p>
                <span class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-deep-600 transition group-hover:gap-3 group-hover:text-aqua-600">
                  Read <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
