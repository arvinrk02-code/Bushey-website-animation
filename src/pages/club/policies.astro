---
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";
import { clubDocuments, governingBodyDocuments, privacyNoticeHref } from "../../data/documents";

function downloadLabel(type: "pdf" | "doc") {
  return type === "pdf" ? "Download PDF" : "Download document";
}
---

<Base
  title="Policies & documents"
  description="Bushey ASC policies and documents, constitution, codes of conduct, safeguarding, privacy and club governance."
>
  <PageHero
    eyebrow="The club"
    title="Policies & documents"
    strap="Constitution, codes of conduct, gala consent forms and club policies. Governing body documents link through to Swim England."
    compact
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <div class="reveal">
        <h2 class="display text-2xl text-deep-800">Club documents</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          {
            clubDocuments.map((doc, i) => (
              <a
                href={doc.href}
                target="_blank"
                rel="noopener"
                class="card-lift group flex gap-4 rounded-2xl border border-foam-200 bg-white p-5 transition hover:border-aqua-300"
                style={`--reveal-delay: ${(i % 4) * 0.04}s`}
              >
                <span
                  class:list={[
                    "flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-xs font-bold uppercase",
                    doc.type === "pdf" ? "bg-red-50 text-red-600" : "bg-blue-50 text-blue-700",
                  ]}
                  aria-hidden="true"
                >
                  {doc.type}
                </span>
                <span class="min-w-0">
                  <span class="block font-bold text-deep-800 transition group-hover:text-aqua-600">{doc.name}</span>
                  <span class="mt-1 block text-sm leading-relaxed text-ink-600">{doc.desc}</span>
                  <span class="mt-3 inline-block text-sm font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4">
                    {downloadLabel(doc.type)} →
                  </span>
                </span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="reveal mt-14">
        <h2 class="display text-2xl text-deep-800">Governing body documents</h2>
        <p class="mt-2 text-sm text-ink-600">National policies hosted by Swim England.</p>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          {
            governingBodyDocuments.map((doc, i) => (
              <a
                href={doc.href}
                target="_blank"
                rel="noopener"
                class="card-lift group flex gap-4 rounded-2xl border border-foam-200 bg-white p-5 transition hover:border-aqua-300"
                style={`--reveal-delay: ${(i % 4) * 0.04}s`}
              >
                <span
                  class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-deep-50 text-sm font-bold text-deep-600"
                  aria-hidden="true"
                >
                  SE
                </span>
                <span class="min-w-0">
                  <span class="block font-bold text-deep-800 transition group-hover:text-aqua-600">{doc.name}</span>
                  <span class="mt-1 block text-sm leading-relaxed text-ink-600">{doc.desc}</span>
                  <span class="mt-3 inline-block text-sm font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4">
                    View at Swim England ↗
                  </span>
                </span>
              </a>
            ))
          }
        </div>
      </div>

      <div id="privacy" class="reveal mt-14 rounded-3xl border border-foam-200 bg-foam-50 p-8">
        <h2 class="display text-xl text-deep-800">Member privacy</h2>
        <p class="mt-3 max-w-3xl text-sm leading-relaxed text-ink-600">
          In line with Swim England advice, information about members on this website is restricted to name,
          age group and swimming results. Parts of the website are password protected via SwimManager, with
          access restricted to members only.
        </p>
        <a
          href={privacyNoticeHref}
          target="_blank"
          rel="noopener"
          class="mt-4 inline-block text-sm font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600"
        >
          View privacy notice in full →
        </a>
      </div>

      <p class="reveal mt-10 text-sm leading-relaxed text-ink-600">
        Safeguarding concern? Don't request a document, go straight to the{" "}
        <a href="/welfare" class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">Welfare page</a>{" "}
        for immediate contacts.
      </p>
    </div>
  </section>

  <CtaBand />
</Base>
