---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import heroImage from "../assets/welcome-slider.png";
import Base from "../layouts/Base.astro";
import WaterCanvas from "../components/WaterCanvas.astro";
import WaveDivider from "../components/WaveDivider.astro";
import SquadPathway from "../components/SquadPathway.astro";
import SectionHeader from "../components/SectionHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";
import { upcomingGalas } from "../data/galas";

const news = (await getCollection("news"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const galas = upcomingGalas(
  (await getCollection("fixtures")).map((f) => f.data),
  4,
);

const hub = (await getCollection("hub")).sort((a, b) => a.data.order - b.data.order);

const MONTH_SHORT = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
---

<Base title={site.shortName} description="Bushey Amateur Swimming Club, one hundred years of technique-first swimming in Hertfordshire. Squads from age 5 to Masters, county-level competition, and a friendly volunteer-run community.">
  <!-- ============ HERO ============ -->
  <section class="relative flex min-h-[94svh] items-center overflow-hidden bg-white">
    <div
      class="absolute inset-0"
      style="background:
        radial-gradient(120% 100% at 82% -20%, color-mix(in srgb, var(--color-aqua-400) 20%, transparent) 0%, transparent 52%),
        radial-gradient(90% 80% at -8% 112%, color-mix(in srgb, var(--color-foam-200) 85%, transparent) 0%, transparent 58%),
        linear-gradient(180deg, var(--color-foam-50) 0%, #ffffff 78%);"
      aria-hidden="true"
    >
    </div>
    <WaterCanvas variant="light" />
    <div class="pointer-events-none absolute inset-x-0 top-[58%] hidden h-px opacity-50 lg:block hairline-aqua" aria-hidden="true"></div>

    <div class="relative mx-auto w-full max-w-7xl px-5 pb-28 pt-32 sm:px-8 sm:pt-36">
      <div class="grid items-center gap-14 lg:grid-cols-[1.02fr_0.98fr]">
        <div>
          <p class="reveal flex flex-wrap items-center gap-3 text-xs font-bold uppercase tracking-[0.26em] text-aqua-600">
            <span class="inline-block h-px w-12 hairline-aqua" aria-hidden="true"></span>
            Bushey Amateur Swimming Club · Hertfordshire
          </p>

          <h1 class="display reveal mt-7 text-[clamp(3rem,7.5vw,6rem)] leading-[0.88]" style="--reveal-delay: 0.08s">
            <span class="block text-deep-800">A century</span>
            <span class="shimmer-text-ink block">in the water.</span>
          </h1>

          <p class="reveal mt-8 max-w-xl text-lg leading-relaxed text-ink-600 sm:text-xl" style="--reveal-delay: 0.18s">
            Founded 1926. Volunteer-run, technique-first, and still putting local swimmers on the
            blocks every weekend. From first lengths at five to county finals at eighteen. This is
            where Bushey swims.
          </p>

          <div class="reveal mt-11 flex flex-wrap items-center gap-4" style="--reveal-delay: 0.28s">
            <a
              href="/join"
              class="magnetic press btn-glow group inline-flex items-center gap-3 rounded-full bg-deep-800 px-8 py-4 text-base font-bold text-white shadow-lg shadow-deep-900/15 transition hover:bg-deep-700 hover:shadow-xl hover:shadow-deep-800/25"
            >
              Join the club
              <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
            </a>
            <a
              href="/train/squads"
              class="magnetic press group inline-flex items-center gap-3 rounded-full border border-deep-800/15 bg-white/60 px-8 py-4 text-base font-bold text-deep-800 backdrop-blur-sm transition hover:border-aqua-400 hover:text-aqua-600"
            >
              Explore the squads
            </a>
          </div>
        </div>

        <!-- Hero image -->
        <div class="reveal relative isolate mx-auto w-full max-w-lg lg:max-w-none" style="--reveal-delay: 0.2s">
          <div class="pointer-events-none absolute -inset-4 -z-10 -rotate-2 rounded-[2.4rem] border border-gold-400/45" aria-hidden="true"></div>
          <div class="float-slow overflow-hidden rounded-[2rem]" style="box-shadow: var(--shadow-frame)">
            <Picture
              src={heroImage}
              formats={["avif", "webp"]}
              widths={[480, 768, 1024, 1500]}
              sizes="(min-width: 1024px) 512px, 100vw"
              alt="A Bushey ASC swimmer mid-butterfly stroke"
              class="block w-full object-cover"
              pictureAttributes={{ class: "block" }}
              loading="eager"
              fetchpriority="high"
            />
          </div>
          <div class="absolute -bottom-6 -left-4 flex items-center gap-3 rounded-2xl border border-foam-200 bg-white/85 px-5 py-3.5 shadow-[var(--shadow-float)] backdrop-blur-md sm:-left-6">
            <img src="/images/centenary-badge.png" alt="" class="h-11 w-11 object-contain" width="44" height="44" />
            <div class="leading-tight">
              <p class="display text-base text-deep-800">100 years</p>
              <p class="text-xs font-semibold text-ink-400">of Bushey swimming</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="pointer-events-none absolute bottom-24 left-1/2 hidden -translate-x-1/2 text-deep-800/35 lg:block" aria-hidden="true">
      <svg class="scroll-cue h-5 w-5" viewBox="0 0 16 16" fill="none"><path d="M8 2v11M3.5 8.5L8 13l4.5-4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path></svg>
    </div>

    <WaveDivider fill="var(--color-gold-400)" class="z-10" />
  </section>

  <!-- ============ CENTENARY BAND ============ -->
  <section class="bg-gold-400">
    <a href="/club/centenary" class="group block">
      <div class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-4 px-5 py-8 sm:flex-row sm:items-center sm:px-8">
        <div class="flex items-center gap-5">
          <span class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-deep-900 p-2.5">
            <img src="/images/centenary-badge.png" alt="" class="h-full w-full object-contain" width="44" height="44" loading="lazy" />
          </span>
          <span class="display text-5xl text-deep-900 sm:text-6xl">1926<span class="text-deep-900/40">–</span>2026</span>
        </div>
        <p class="max-w-md text-sm font-semibold leading-snug text-deep-900/80">
          This is our centenary year. Explore one hundred years of Bushey swimming, and help us
          tell the story.
        </p>
        <span class="inline-flex items-center gap-2 rounded-full bg-deep-900 px-6 py-3 text-sm font-bold text-gold-300 transition group-hover:gap-3.5">
          The centenary <span aria-hidden="true">→</span>
        </span>
      </div>
    </a>
  </section>

  <!-- ============ SQUAD PATHWAY (dark accent section) ============ -->
  <section class="relative overflow-hidden bg-deep-900 py-20 text-white sm:py-28">
    <div
      class="absolute inset-0"
      style="background: radial-gradient(80% 100% at 90% 10%, color-mix(in srgb, var(--color-aqua-500) 14%, transparent) 0%, transparent 55%);"
      aria-hidden="true"
    >
    </div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <SectionHeader
        dark
        title="One lane, seven steps"
        strap="Every Bushey swimmer follows the same pathway, from first strokes in Dolphins to county finals with Performance. Tap a squad to see where your swimmer fits."
      />
      <div class="reveal mt-12" style="--reveal-delay: 0.15s">
        <SquadPathway />
      </div>
    </div>
  </section>

  <!-- ============ NEWS + FIXTURES ============ -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="grid gap-16 lg:grid-cols-[1.6fr_1fr]">
        <!-- News -->
        <div>
          <div class="flex flex-wrap items-end justify-between gap-4">
            <SectionHeader title="Club news" />
            <a href="/news" class="swim-link reveal mb-1 inline-block py-1 text-sm font-bold text-deep-600 hover:text-aqua-600">
              All news →
            </a>
          </div>
          <div class="mt-10 grid gap-6">
            {
              news.map((post, i) => (
                <a
                  href={`/news/${post.id}`}
                  class="card-lift reveal group grid overflow-hidden rounded-3xl border border-foam-200 bg-foam-50 sm:grid-cols-[180px_1fr]"
                  style={`--reveal-delay: ${i * 0.08}s`}
                >
                  {
                    post.data.image ? (
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt ?? ""}
                        class="h-36 w-full object-cover sm:h-full"
                        width="360"
                        height="240"
                        loading="lazy"
                      />
                    ) : (
                      <div class="flex h-36 items-center justify-center bg-deep-900 sm:h-full" aria-hidden="true">
                        <img src="/images/basc-logo-round.jpeg" alt="" class="h-16 w-16 rounded-full object-cover opacity-90" width="64" height="64" loading="lazy" />
                      </div>
                    )
                  }
                  <div class="p-6">
                    <span class="text-xs font-bold uppercase tracking-[0.18em] text-gold-600">
                      {post.data.category} · {post.data.date.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" })}
                    </span>
                    <h3 class="mt-1.5 text-xl font-bold text-deep-800 transition group-hover:text-aqua-600">{post.data.title}</h3>
                    <p class="mt-2 text-sm leading-relaxed text-ink-600">{post.data.excerpt}</p>
                  </div>
                </a>
              ))
            }
          </div>
        </div>

        <!-- Upcoming galas -->
        <div>
          <div class="flex flex-wrap items-end justify-between gap-4">
            <SectionHeader title="Typical season ahead" />
            <a href="/compete/fixtures" class="swim-link reveal mb-1 inline-block py-1 text-sm font-bold text-deep-600 hover:text-aqua-600">
              Upcoming galas →
            </a>
          </div>
          <div class="mt-10 overflow-hidden rounded-3xl bg-deep-900">
            {
              galas.map((gala, i) => (
                <div class:list={["reveal p-6", i > 0 && "border-t border-white/10"]} style={`--reveal-delay: ${i * 0.08}s`}>
                  <p class="text-xs font-bold uppercase tracking-wider text-aqua-400">{MONTH_SHORT[gala.month - 1]} · {gala.level}</p>
                  <h3 class="mt-1.5 font-bold text-white">{gala.name}</h3>
                  <p class="mt-1 text-sm text-white/55">{gala.typicalTiming}</p>
                </div>
              ))
            }
            <a href="/compete/guide" class="block bg-aqua-400 p-5 text-center text-sm font-bold text-deep-900 transition hover:bg-aqua-300">
              First gala? Read our competing guide →
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ ATHLETE HUB TEASER ============ -->
  <section class="relative overflow-hidden bg-foam-50 py-20 sm:py-28">
    <div class="pointer-events-none absolute -left-10 bottom-0 select-none" aria-hidden="true">
      <span class="display text-outline text-[14rem] leading-none text-deep-800/8">HUB</span>
    </div>
    <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
      <SectionHeader
        eyebrow="The Athlete Hub"
        title="There's more to it than the pool"
        strap="Food, sleep, land training, kit and recovery. Practical guides from Swim England for our squads and parents."
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          hub.map((article, i) => (
            <a
              href={`/athlete-hub/${article.id}`}
              class="card-lift reveal group rounded-3xl border border-foam-200 bg-white p-7"
              style={`--reveal-delay: ${(i % 3) * 0.08}s`}
            >
              <span class="display block text-xs text-aqua-600" style="font-variation-settings: 'wdth' 90;">0{article.data.order}</span>
              <h3 class="display mt-3 text-2xl text-deep-800 transition group-hover:text-aqua-600">{article.data.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-600">{article.data.strap}</p>
              <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-deep-600 transition group-hover:gap-3 group-hover:text-aqua-600">
                Read <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
