---
import { getCollection, render } from "astro:content";
import Base from "../../../layouts/Base.astro";
import PageHero from "../../../components/PageHero.astro";
import CtaBand from "../../../components/CtaBand.astro";
import { kitEssentials, kitNotes, squadKit } from "../../../data/squadKit";

export async function getStaticPaths() {
  const squads = await getCollection("squads");
  return squads.map((squad) => ({ params: { slug: squad.id }, props: { squad } }));
}

const { squad } = Astro.props;
const { Content } = await render(squad);

const all = (await getCollection("squads")).sort((a, b) => a.data.order - b.data.order);
const nextSquad = squad.data.next ? all.find((s) => s.id === squad.data.next) : undefined;
const prevSquad = all.find((s) => s.data.next === squad.id);
const kit = squadKit[squad.id] ?? [];
---

<Base
  title={`${squad.data.name} squad`}
  description={`${squad.data.name} squad at Bushey ASC, ${squad.data.strap}`}
>
  <PageHero eyebrow={`Squad ${squad.data.order} · ${squad.data.tag}`} title={squad.data.name} strap={squad.data.strap} compact>
    <dl class="reveal mt-8 flex flex-wrap gap-x-12 gap-y-4" style="--reveal-delay: 0.22s">
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Ages</dt>
        <dd class="display mt-1 text-2xl text-aqua-600">{squad.data.ageGuide}</dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Water time</dt>
        <dd class="display mt-1 text-2xl text-aqua-600">{squad.data.hoursPerWeek}</dd>
      </div>
      <div>
        <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Sessions per week</dt>
        <dd class="display mt-1 text-2xl text-aqua-600">{squad.data.sessions.length || ", "}</dd>
      </div>
    </dl>
  </PageHero>

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto grid max-w-7xl gap-14 px-5 sm:px-8 lg:grid-cols-[1.5fr_1fr]">
      <div>
        <div class="prose-club reveal">
          <Content />
        </div>

        <div class="reveal mt-10">
          <h2 class="display text-2xl text-deep-800">Required kit</h2>
          <p class="mt-3 text-sm leading-relaxed text-ink-600">{kitEssentials}</p>
          {
            kitNotes.map((note) => (
              <p class="mt-2 text-sm leading-relaxed text-ink-600">{note}</p>
            ))
          }

          {
            kit.length > 0 ? (
              <div class="mt-6 grid gap-5 sm:grid-cols-2">
                {
                  kit.map((item) => (
                    <article class="flex flex-col rounded-3xl border border-foam-200 bg-foam-50 p-5">
                      <div class="flex h-40 items-center justify-center">
                        <img
                          src={item.image}
                          alt=""
                          class="max-h-full max-w-full object-contain"
                          width="200"
                          height="160"
                          loading="lazy"
                        />
                      </div>
                      <h3 class="display mt-4 text-lg text-deep-800">{item.name}</h3>
                      <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">{item.description}</p>
                    </article>
                  ))
                }
              </div>
            ) : (
              <p class="mt-4 text-sm leading-relaxed text-ink-600">
                Masters swimmers need the essentials above. Training aids are arranged with your coach.
              </p>
            )
          }

          <p class="mt-6 text-sm leading-relaxed text-ink-600">
            Club kit (T-shirts, swimming hats and more) is on the{" "}
            <a href="/club/kit" class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">
              club kit page
            </a>.
          </p>
        </div>

        <div class="reveal mt-10 grid gap-6 sm:grid-cols-2">
          <div class="rounded-3xl border border-foam-200 bg-white p-7">
            <h2 class="display text-lg text-deep-800">Entry criteria</h2>
            <ul class="mt-4 space-y-3">
              {
                squad.data.entry.map((item) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-ink-600">
                    <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-aqua-500" aria-hidden="true" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
          <div class="rounded-3xl bg-deep-900 p-7 text-white">
            <h2 class="display text-lg">What we work on</h2>
            <ul class="mt-4 space-y-3">
              {
                squad.data.focus.map((item) => (
                  <li class="flex gap-3 text-sm leading-relaxed text-white/75">
                    <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-gold-400" aria-hidden="true" />
                    {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Prev / next squads -->
        <div class="reveal mt-10 flex flex-col gap-4 sm:flex-row">
          {
            prevSquad && (
              <a href={`/train/squads/${prevSquad.id}`} class="group flex-1 rounded-2xl border border-foam-200 bg-white p-5 transition hover:border-aqua-400">
                <span class="text-xs font-bold uppercase tracking-wider text-ink-400">← Previous squad</span>
                <span class="mt-1 block font-bold text-deep-800 group-hover:text-aqua-600">{prevSquad.data.name}</span>
              </a>
            )
          }
          {
            nextSquad && (
              <a href={`/train/squads/${nextSquad.id}`} class="group flex-1 rounded-2xl border border-foam-200 bg-white p-5 text-right transition hover:border-aqua-400">
                <span class="text-xs font-bold uppercase tracking-wider text-ink-400">Next step →</span>
                <span class="mt-1 block font-bold text-deep-800 group-hover:text-aqua-600">{nextSquad.data.name}</span>
              </a>
            )
          }
        </div>
      </div>

      <aside class="reveal" style="--reveal-delay: 0.1s">
        <div class="sticky top-28 space-y-6">
          <div class="overflow-hidden rounded-3xl bg-deep-900">
            <div class="bg-aqua-400 px-6 py-4">
              <h2 class="display text-lg text-deep-900">Weekly sessions</h2>
            </div>
            {
              squad.data.sessions.length > 0 ? (
                <ul>
                  {squad.data.sessions.map((s, i) => (
                    <li class:list={["flex items-baseline justify-between gap-4 px-6 py-4", i > 0 && "border-t border-white/10"]}>
                      <div>
                        <p class="font-bold text-white">{s.day}</p>
                        <p class="text-sm text-white/55">
                          {s.location}
                          {s.note && <span class="ml-2 rounded-full bg-gold-400/20 px-2 py-0.5 text-xs font-semibold text-gold-300">{s.note}</span>}
                        </p>
                      </div>
                      <p class="whitespace-nowrap font-mono text-sm text-aqua-300">
                        {s.start}–{s.end}
                      </p>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="px-6 py-5 text-sm text-white/60">Sessions arranged individually, contact the club.</p>
              )
            }
            <a href="/train/timetable" class="block border-t border-white/10 px-6 py-4 text-sm font-bold text-aqua-300 transition hover:bg-white/5">
              Full club timetable →
            </a>
          </div>

          <div class="rounded-3xl border border-foam-200 bg-white p-6">
            <h2 class="display text-lg text-deep-800">More on kit</h2>
            <p class="mt-2 text-sm leading-relaxed text-ink-600">
              What to buy, what to skip, and how kit builds through the squads.
            </p>
            <a href="/athlete-hub/equipment" class="mt-4 inline-block text-sm font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">
              Equipment guide →
            </a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <CtaBand />
</Base>
