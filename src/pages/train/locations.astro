---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const locations = await getCollection("locations");
---

<Base
  title="Pool locations"
  description="Where Bushey ASC trains, five pools across Hertfordshire and north-west London, including 50m long-course water at Luton."
>
  <PageHero
    eyebrow="Train"
    title="Where we swim"
    strap="Home base at Bushey Grove, plus four more pools that give our squads the water they need, right up to a 50m Olympic-standard pool."
    compact
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <div class="grid gap-6 lg:grid-cols-2">
        {
          locations.map((loc, i) => (
            <article class="card-lift reveal overflow-hidden rounded-3xl border border-foam-200 bg-white" style={`--reveal-delay: ${(i % 2) * 0.08}s`}>
              {loc.data.photo && (
                <div class="relative">
                  <img
                    src={loc.data.photo}
                    alt={loc.data.name}
                    class="h-52 w-full object-cover sm:h-60"
                    width="768"
                    height="512"
                    loading="lazy"
                  />
                  {loc.data.id === "bushey-grove" && (
                    <span class="absolute left-4 top-4 rounded-full bg-gold-400 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-deep-900">
                      Home pool
                    </span>
                  )}
                  {loc.data.id === "luton" && (
                    <span class="absolute left-4 top-4 rounded-full bg-deep-900 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-aqua-300">
                      50m long course
                    </span>
                  )}
                </div>
              )}
              <div class="p-8">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <h2 class="display text-2xl text-deep-800">{loc.data.name}</h2>
                    <p class="mt-1.5 text-sm text-ink-600">{loc.data.address}</p>
                  </div>
                  <span class="shrink-0 rounded-full bg-aqua-400/15 px-3 py-1.5 text-xs font-bold text-aqua-600">{loc.data.length}</span>
                </div>
                {loc.data.note && <p class="mt-4 text-sm leading-relaxed text-ink-600">{loc.data.note}</p>}
                <div class="mt-5 flex flex-wrap items-center gap-4 text-sm">
                  <span class="flex items-center gap-2 text-ink-400">
                    <span aria-hidden="true">🅿</span> {loc.data.parking}
                  </span>
                  <a
                    href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(loc.data.mapQuery)}`}
                    target="_blank"
                    rel="noopener"
                    class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600"
                  >
                    Open in Google Maps ↗
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
