---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageHero from "../../components/PageHero.astro";
import CtaBand from "../../components/CtaBand.astro";

const all = (await getCollection("coaches")).map((c) => c.data);
const headCoach = all.find((c) => c.group === "Head Coach");
const coaches = all.filter((c) => c.group === "Coaches");
const teachers = all.filter((c) => c.group === "Teachers");
---

<Base
  title="Coaches & teachers"
  description="Meet the Swim England qualified, DBS-checked coaching and teaching team on poolside at Bushey ASC, led by Head Coach Oliver Spisak."
>
  <PageHero
    eyebrow="Train"
    title="The team on poolside"
    strap="Swim England qualified, DBS-checked and safeguarding-trained, and most of them volunteers. These are the people who turn lengths into race wins."
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-7xl px-5 sm:px-8">
      <!-- Head Coach feature -->
      {
        headCoach && (
          <div class="reveal overflow-hidden rounded-3xl bg-deep-900 text-white">
            <div class="grid items-center gap-8 p-8 sm:p-10 lg:grid-cols-[auto_1fr]">
              <img
                src={headCoach.photo}
                alt={`${headCoach.name}, ${headCoach.role} at Bushey ASC`}
                class="h-44 w-44 rounded-3xl object-cover ring-4 ring-aqua-400/40 sm:h-52 sm:w-52"
                width="208"
                height="208"
              />
              <div>
                <p class="eyebrow text-aqua-400">{headCoach.role}</p>
                <h2 class="display mt-2 text-4xl">{headCoach.name}</h2>
                <p class="mt-4 max-w-xl text-sm leading-relaxed text-white/70">
                  Leads the coaching programme across the club, setting the season plan for the top
                  squads and the technical standards that run all the way down to Dolphins.
                </p>
                <div class="mt-5 flex flex-wrap gap-2">
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-bold text-white/80">Swim England qualified</span>
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-bold text-white/80">DBS checked</span>
                  <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-bold text-white/80">Safeguarding trained</span>
                </div>
              </div>
            </div>
          </div>
        )
      }

      <!-- Coaches -->
      <div class="mt-14">
        <h2 class="display reveal text-2xl text-deep-800">Coaches</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-2">
          {
            coaches.map((c, i) => (
              <div class="card-lift reveal flex items-center gap-5 rounded-3xl border border-foam-200 bg-foam-50 p-6" style={`--reveal-delay: ${(i % 2) * 0.07}s`}>
                {c.photo ? (
                  <img src={c.photo} alt={`${c.name}, ${c.role}`} class="h-20 w-20 rounded-2xl object-cover" width="80" height="80" loading="lazy" />
                ) : (
                  <span class="flex h-20 w-20 shrink-0 items-center justify-center rounded-2xl bg-deep-800 font-display text-2xl font-extrabold text-aqua-300" style="font-variation-settings: 'wdth' 90;" aria-hidden="true">
                    {c.name.charAt(0)}
                  </span>
                )}
                <div>
                  <h3 class="display text-xl text-deep-800">{c.name}</h3>
                  <p class="mt-1 text-sm font-bold text-aqua-600">{c.role}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Teachers -->
      <div class="mt-14">
        <h2 class="display reveal text-2xl text-deep-800">Teachers</h2>
        <div class="mt-6 grid grid-cols-2 gap-5 sm:grid-cols-3 lg:grid-cols-4">
          {
            teachers.map((t, i) => (
              <div class="card-lift reveal rounded-3xl border border-foam-200 bg-white p-6 text-center" style={`--reveal-delay: ${(i % 4) * 0.06}s`}>
                {t.photo ? (
                  <img src={t.photo} alt={`${t.name}, ${t.role}`} class="mx-auto h-24 w-24 rounded-full object-cover ring-2 ring-foam-200" width="96" height="96" loading="lazy" />
                ) : (
                  <span class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-foam-100 font-display text-2xl font-extrabold text-deep-600" style="font-variation-settings: 'wdth' 90;" aria-hidden="true">
                    {t.name.charAt(0)}
                  </span>
                )}
                <h3 class="mt-4 font-bold text-deep-800">{t.name}</h3>
                <p class="mt-1 text-xs font-bold uppercase tracking-wider text-aqua-600">{t.role}</p>
              </div>
            ))
          }
        </div>
      </div>

      <p class="reveal mt-8 text-sm text-ink-600">
        Every member of the poolside team holds an enhanced DBS check and safeguarding training, in
        line with our <a href="/welfare" class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">welfare commitments</a>.
      </p>

      <div class="reveal mt-12 rounded-3xl bg-deep-900 p-8 text-white sm:p-10">
        <div class="flex flex-col items-start justify-between gap-6 lg:flex-row lg:items-center">
          <div class="max-w-2xl">
            <h2 class="display text-2xl">Fancy joining the poolside team?</h2>
            <p class="mt-3 text-sm leading-relaxed text-white/65">
              We support parents and older swimmers through teaching and coaching qualifications, several of the team above started exactly that way. The club funds training for
              committed volunteers.
            </p>
          </div>
          <a href="/club/volunteering" class="shrink-0 rounded-full bg-aqua-400 px-7 py-3.5 text-sm font-bold text-deep-900 transition hover:bg-aqua-300">
            Volunteering at BASC →
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>
