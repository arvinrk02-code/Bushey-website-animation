---
import Base from "../layouts/Base.astro";
import PageHero from "../components/PageHero.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../data/site";

const externalContacts = [
  { name: "County Welfare Officer", contact: "welfare@swimherts.org", href: "mailto:welfare@swimherts.org" },
  { name: "East Region Welfare Team", contact: "eastwelfare@swimming.org", href: "mailto:eastwelfare@swimming.org" },
  { name: "Swim England Safeguarding Team", contact: "safeguarding@swimming.org", href: "mailto:safeguarding@swimming.org" },
];

const usefulResources = [
  {
    name: "Childline",
    desc: "A free, confidential helpline and online service for children and young people up to age 19 in the UK, run by the NSPCC.",
    phone: "0800 1111",
    phoneHref: "tel:08001111",
    href: "https://www.childline.org.uk/",
  },
  {
    name: "NSPCC",
    desc: "National Society for the Prevention of Cruelty to Children. Worried about a child? Contact their helpline.",
    phone: "0808 800 5000",
    phoneHref: "tel:08088005000",
    email: "help@nspcc.org.uk",
    emailHref: "mailto:help@nspcc.org.uk",
    href: "https://www.nspcc.org.uk/",
  },
  {
    name: "Kooth",
    desc: "A free, anonymous online mental health and wellbeing service for children and young people, with text-based chat, self-help resources and community forums (ages 16+).",
    href: "https://www.kooth.com/",
  },
];

---

<Base
  title="Welfare"
  description="Safeguarding and welfare at Bushey ASC, how we follow Wavepower, how to contact our Welfare Officer, and external support for children and families."
>
  <PageHero
    eyebrow="Welfare"
    title="Safe, positive, welcoming"
    strap="The safety and wellbeing of every swimmer is our top priority, above results, above everything. Here's how we protect it, and exactly who to talk to if something's not right."
    compact
  />

  <section class="bg-white py-16 sm:py-24">
    <div class="mx-auto max-w-5xl px-5 sm:px-8">
      <!-- Priority contact card -->
      <div class="reveal overflow-hidden rounded-3xl bg-deep-900 text-white">
        <div class="p-8 sm:p-10">
          <p class="eyebrow text-aqua-400">Something on your mind?</p>
          <h2 class="display mt-2 text-3xl">Talk to the Welfare Officer</h2>
          <p class="mt-4 max-w-2xl leading-relaxed text-white/70">
            Our trained Welfare Officer is <strong class="text-white">independent of the coaching team and the
            committee</strong>, any child, parent or member can raise a question or concern in confidence.
            Every concern is taken seriously, handled promptly and sensitively in line with Wavepower,
            with the child's best interests at the heart of every decision.
          </p>
          <a
            href={`mailto:${site.welfareEmail}`}
            class="mt-8 inline-flex items-center gap-3 rounded-full bg-aqua-400 px-8 py-4 text-base font-bold text-deep-900 transition hover:bg-aqua-300"
          >
            {site.welfareEmail}
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <!-- Our approach -->
      <div class="reveal mt-14">
        <h2 class="display text-2xl text-deep-800">Our approach</h2>
        <div class="mt-6 grid items-start gap-8 sm:grid-cols-[1fr_200px]">
          <div class="prose-club max-w-none sm:order-1">
            <p>
              We follow <strong>Wavepower</strong>, the Swim England safeguarding policy and
              procedures, in full. Every swimmer, whatever their age, background, ability or identity, has the right to take part free from harm, with respect and support from everyone
              around them.
            </p>
          </div>
          <a
            href="https://www.swimming.org/swimengland/wavepower-child-safeguarding-for-clubs/"
            target="_blank"
            rel="noopener"
            class="card-lift order-2 hidden overflow-hidden rounded-2xl border border-foam-200 sm:block"
            aria-label="Wavepower, Swim England safeguarding policy"
          >
            <img src="/images/wavepower.jpg" alt="" class="w-full object-cover" width="200" height="113" loading="lazy" />
            <span class="block px-4 py-3 text-xs font-bold text-deep-600">Wavepower, read the full policy ↗</span>
          </a>
        </div>
        <div class="prose-club mt-2 max-w-none">
          <ul>
            <li>All coaches, teachers and volunteers are recruited in line with the Safe Recruitment Policy.</li>
            <li>Everyone in a position of trust holds an enhanced DBS check and safeguarding training.</li>
            <li>All members follow our Codes of Conduct, aligned to Wavepower standards.</li>
            <li>Welfare Officer contact details are shared with all members and displayed at training.</li>
          </ul>
        </div>
      </div>

      <!-- Beyond the club -->
      <div class="reveal mt-14">
        <h2 class="display text-2xl text-deep-800">External support</h2>
        <p class="mt-3 max-w-2xl text-ink-600">
          For support beyond the club, you can contact your county, regional or national teams. You don't need the club's permission, ever.
        </p>
        <ul class="mt-6 overflow-hidden rounded-3xl border border-foam-200 bg-white">
          {
            externalContacts.map((c, i) => (
              <li class:list={["flex flex-col justify-between gap-1 p-6 sm:flex-row sm:items-center", i > 0 && "border-t border-foam-100"]}>
                <p class="font-bold text-deep-800">{c.name}</p>
                <a href={c.href} class="text-sm font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">
                  {c.contact}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Useful resources -->
      <div class="reveal mt-14">
        <h2 class="display text-2xl text-deep-800">Useful resources</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {
            usefulResources.map((resource, i) => (
              <div
                class="flex flex-col rounded-2xl border border-foam-200 bg-white p-6"
                style={`--reveal-delay: ${(i % 3) * 0.05}s`}
              >
                <h3 class="font-bold text-deep-800">{resource.name}</h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-600">{resource.desc}</p>
                <div class="mt-4 space-y-1 text-sm">
                  {"phone" in resource && resource.phone && (
                    <p>
                      Call for free on{" "}
                      <a href={resource.phoneHref} class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">
                        {resource.phone}
                      </a>
                    </p>
                  )}
                  {"email" in resource && resource.email && (
                    <p>
                      Email{" "}
                      <a href={resource.emailHref} class="font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600">
                        {resource.email}
                      </a>
                    </p>
                  )}
                  <a
                    href={resource.href}
                    target="_blank"
                    rel="noopener"
                    class="inline-block font-bold text-deep-600 underline decoration-aqua-400 underline-offset-4 hover:text-aqua-600"
                  >
                    Visit {resource.name} ↗
                  </a>
                </div>
              </div>
            ))
          }
        </div>
      </div>

    </div>
  </section>

  <CtaBand />
</Base>
